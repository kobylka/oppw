+        if value >= 0.0:
+            return "B"
+        c_reasons = {"BE", "BH", "BEO", "BEPRE", "BREAK_EVEN", "BREAK_EVEN_EXIT"}
+        if reason in c_reasons or reason.startswith("TSL") or "BREAK_EVEN" in reason:
+            return "C"
+        return "D"
